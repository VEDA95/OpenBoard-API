{
  "name": "OpenBoard-API",
  "version": "1.0.0",
  "description": "Rest API backend for the Open Baord Kanban Board Project.",
  "main": "./dist/server.js",
  "scripts": {
    "test": "mocha --require ts-node/register ./tests/**/*.ts",
    "migrate:up": "node-pg-migrate up ${N} -f ./migrations/config.json -m ./migrations",
    "migrate:down": "node-pg-migrate down ${N} -f ./migrations/config.json -m ./migrations",
    "migrate:redo": "node-pg-migrate redo ${N} -f ./migrations/config.json -m ./migrations redo",
    "migrate:create": "node-pg-migrate create ${N} -f ./migrations/config.json -j sql -m ./migrations",
    "build": "tsc -p tsconfig.json",
    "dev": "NODE_ENV=development ts-node --files ./src/server.ts",
    "start": "NODE_ENV=production node ./dist/server.js"
  },
  "keywords": [
    "Kanabn",
    "REST"
  ],
  "author": "Stefan Netterfield",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/chai": "^4.3.6",
    "@types/mocha": "^10.0.2",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.10.3",
    "chai": "^4.3.10",
    "chai-http": "^4.4.0",
    "mocha": "^10.2.0",
    "pino-pretty": "^10.2.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "fastify": "^4.23.2",
    "fastify-plugin": "^4.5.1",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3"
  }
}
