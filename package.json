{
  "name": "OpenBoard-API",
  "version": "1.0.0",
  "description": "Rest API backend for the Open Baord Kanban Board Project.",
  "main": "./dist/server.js",
  "scripts": {
    "test": "NODE_ENV=development jest --detectOpenHandles --forceExit",
    "migrate:up": "node-pg-migrate up ${2:N} -d DATABASE_URI -m ./migrations --envPath $1",
    "migrate:down": "node-pg-migrate down ${2:N} -d DATABASE_URI -m ./migrations --envPath $1",
    "migrate:redo": "node-pg-migrate redo ${2:N} -d DATABASE_URI -m ./migrations --envPath $1",
    "migrate:create": "node-pg-migrate create ${N} -j sql -m ./migrations",
    "build": "tsc -p tsconfig.json",
    "dev": "NODE_ENV=development ts-node --files ./src/server.ts",
    "start": "NODE_ENV=production node ./dist/server.js"
  },
  "keywords": [
    "Kanabn",
    "REST"
  ],
  "author": "Stefan Netterfield",
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.4",
    "@types/jest": "^29.5.6",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.10.3",
    "jest": "^29.7.0",
    "pino-pretty": "^10.2.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@simplewebauthn/server": "^8.2.0",
    "ajv-errors": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "fastify": "^4.23.2",
    "fastify-plugin": "^4.5.1",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^6.2.2",
    "pg": "^8.11.3",
    "zod": "^3.22.2",
    "zod-to-json-schema": "^3.21.4"
  }
}
